  </main>
  <script>
    const tg = window.Telegram && window.Telegram.WebApp;
    const toast = document.getElementById("toast");
    if (tg) { tg.ready(); tg.expand(); tg.MainButton.setText("Закрыть"); tg.MainButton.show(); tg.MainButton.onClick(()=>tg.close()); }
    function openPage(id, btn){document.querySelectorAll('.page').forEach(p=>p.classList.remove('active'));document.querySelectorAll('.tab').forEach(t=>t.classList.remove('active'));document.getElementById(id).classList.add('active');btn.classList.add('active');}
    function showToast(t){toast.textContent=t;toast.style.display='block';setTimeout(()=>toast.style.display='none',2500);}
    function sendAction(action){const payload=JSON.stringify({type:'balern_mini_app_action',action,ts:Date.now()}); if(tg){tg.sendData(payload);showToast('Отправил: '+action);}else{showToast('Вне Telegram: '+action);}}
    function forgetMemory(){ if(confirm('Точно очистить память этого чата?')) sendAction('memory_forget'); }
  </script>

<script>
function openExternal(url) {
  if (window.Telegram && Telegram.WebApp) {
    Telegram.WebApp.openTelegramLink(url);
  } else {
    window.open(url, "_blank");
  }
}
</script>

</body>
</html>
