<!doctype html>
<html lang="ru">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1,viewport-fit=cover" />
  <title>Balern AI</title>
  <script src="https://telegram.org/js/telegram-web-app.js"></script>
  <style>
    :root{
      --bg:#071018;
      --card:rgba(255,255,255,.075);
      --card2:rgba(255,255,255,.11);
      --stroke:rgba(255,255,255,.14);
      --text:#f4f7fb;
      --muted:rgba(244,247,251,.62);
      --muted2:rgba(244,247,251,.43);
      --accent:#78ffd8;
      --accent2:#8ab7ff;
      --danger:#ff6b8b;
      --radius:18px;
    }

    *{box-sizing:border-box}

    html{
      height:auto;
      min-height:100%;
      overflow-y:auto;
      -webkit-text-size-adjust:100%;
    }

    body{
      margin:0;
      min-height:100vh;
      height:auto;
      overflow-y:auto;
      overflow-x:hidden;
      -webkit-overflow-scrolling:touch;
      overscroll-behavior-y:contain;
      color:var(--text);
      font-family:Inter,system-ui,-apple-system,BlinkMacSystemFont,"Segoe UI",Roboto,Arial,sans-serif;
      background:
        radial-gradient(circle at 18% 0%,rgba(120,255,216,.20),transparent 34%),
        radial-gradient(circle at 96% 10%,rgba(138,183,255,.19),transparent 34%),
        linear-gradient(160deg,#05070d,#071018 58%,#05070d);
    }

    button{
      font-family:inherit;
      -webkit-tap-highlight-color:transparent;
    }

    .app{
      width:100%;
      max-width:720px;
      margin:0 auto;
      padding:14px 12px calc(28px + env(safe-area-inset-bottom));
      min-height:100vh;
    }

    .top{
      display:flex;
      align-items:center;
      gap:10px;
      padding:8px 2px 12px;
    }

    .logo{
      width:40px;
      height:40px;
      border-radius:14px;
      display:grid;
      place-items:center;
      background:linear-gradient(135deg,var(--accent),var(--accent2));
      color:#061016;
      font-weight:950;
      letter-spacing:-.05em;
      flex:0 0 auto;
    }

    .title{
      flex:1;
      min-width:0;
    }

    .title h1{
      margin:0;
      font-size:21px;
      line-height:1;
      letter-spacing:-.04em;
    }

    .title p{
      margin:3px 0 0;
      color:var(--muted);
      font-size:12px;
      white-space:nowrap;
      overflow:hidden;
      text-overflow:ellipsis;
    }

    .chip{
      border:1px solid var(--stroke);
      background:rgba(255,255,255,.06);
      color:var(--muted);
      border-radius:999px;
      padding:7px 9px;
      font-size:11px;
      font-weight:700;
    }

    .hero{
      border:1px solid var(--stroke);
      border-radius:22px;
      background:linear-gradient(135deg,rgba(255,255,255,.10),rgba(255,255,255,.045));
      padding:14px;
      margin-bottom:10px;
    }

    .hero h2{
      margin:0;
      font-size:22px;
      line-height:1.05;
      letter-spacing:-.055em;
    }

    .hero p{
      margin:7px 0 0;
      color:var(--muted);
      font-size:13px;
      line-height:1.35;
    }

    .tabs{
      display:flex;
      gap:7px;
      overflow-x:auto;
      overflow-y:hidden;
      scrollbar-width:none;
      padding:6px 0 12px;
      margin-bottom:2px;
    }

    .tabs::-webkit-scrollbar{display:none}

    .tab{
      flex:0 0 auto;
      border:1px solid var(--stroke);
      background:rgba(255,255,255,.055);
      color:var(--muted);
      padding:9px 11px;
      border-radius:999px;
      font-size:12.5px;
      font-weight:850;
      white-space:nowrap;
    }

    .tab.active{
      color:#03110e;
      background:linear-gradient(135deg,var(--accent),#a3ffe9);
      border-color:rgba(120,255,216,.52);
    }

    .page{display:none}
    .page.active{display:block}

    .section{
      margin:10px 0 14px;
    }

    .section-head{
      display:flex;
      align-items:end;
      justify-content:space-between;
      gap:12px;
      margin:0 2px 8px;
    }

    .section h3{
      margin:0;
      font-size:17px;
      letter-spacing:-.04em;
    }

    .section small{
      color:var(--muted2);
      font-size:11.5px;
      text-align:right;
    }

    .grid{
      display:grid;
      grid-template-columns:1fr;
      gap:8px;
    }

    @media (min-width:520px){
      .grid.two{grid-template-columns:1fr 1fr}
    }

    .btn{
      width:100%;
      border:1px solid var(--stroke);
      border-radius:17px;
      background:linear-gradient(135deg,rgba(255,255,255,.105),rgba(255,255,255,.052));
      color:var(--text);
      display:flex;
      align-items:center;
      justify-content:space-between;
      gap:10px;
      padding:11px 12px;
      text-align:left;
      font-weight:850;
      font-size:13.5px;
      min-height:56px;
    }

    .btn:active{transform:scale(.99)}

    .btn.primary{
      color:#061016;
      background:linear-gradient(135deg,var(--accent),#9eeaff);
      border-color:rgba(120,255,216,.55);
    }

    .btn.danger{
      background:linear-gradient(135deg,rgba(255,107,139,.25),rgba(255,255,255,.055));
      border-color:rgba(255,107,139,.34);
    }

    .btn span{
      min-width:0;
      display:block;
    }

    .btn small{
      display:block;
      color:inherit;
      opacity:.62;
      font-size:11px;
      line-height:1.2;
      margin-top:2px;
      font-weight:750;
    }

    .btn b{
      opacity:.55;
      font-size:19px;
      line-height:1;
      flex:0 0 auto;
    }

    details{
      border:1px solid var(--stroke);
      border-radius:19px;
      background:rgba(255,255,255,.055);
      margin:8px 0;
      overflow:hidden;
    }

    summary{
      cursor:pointer;
      list-style:none;
      padding:13px 13px;
      font-weight:900;
      font-size:14px;
      display:flex;
      justify-content:space-between;
      align-items:center;
      gap:10px;
    }

    summary::-webkit-details-marker{display:none}

    summary:after{
      content:"›";
      opacity:.55;
      font-size:22px;
      transform:rotate(90deg);
    }

    details[open] summary:after{
      transform:rotate(-90deg);
    }

    .details-body{
      padding:0 11px 11px;
    }

    .cmd{
      display:block;
      border:1px solid rgba(255,255,255,.10);
      border-radius:13px;
      background:rgba(0,0,0,.22);
      padding:9px 10px;
      color:var(--muted);
      font-family:ui-monospace,SFMono-Regular,Menlo,Consolas,monospace;
      font-size:11.5px;
      overflow:auto;
      white-space:nowrap;
      margin-top:7px;
    }

    .note{
      color:var(--muted);
      font-size:12px;
      line-height:1.35;
      margin:8px 2px 0;
    }

    .footer{
      margin:24px 0 0;
      color:var(--muted2);
      text-align:center;
      font-size:12px;
      padding-bottom:18px;
    }

    .toast{
      position:fixed;
      z-index:200;
      left:50%;
      bottom:18px;
      transform:translateX(-50%) translateY(14px);
      opacity:0;
      pointer-events:none;
      background:rgba(8,13,20,.94);
      border:1px solid var(--stroke);
      border-radius:999px;
      padding:9px 13px;
      max-width:calc(100vw - 28px);
      color:var(--text);
      white-space:nowrap;
      overflow:hidden;
      text-overflow:ellipsis;
      font-size:12.5px;
      transition:.18s;
    }

    .toast.show{
      opacity:1;
      transform:translateX(-50%) translateY(0);
    }
  </style>
</head>

<body>
  <div class="app">
    <header class="top">
      <div class="logo">BA</div>
      <div class="title">
        <h1>Balern AI</h1>
        <p>compact control panel</p>
      </div>
      <button class="chip" onclick="closeApp()">Закрыть</button>
    </header>

    <section class="hero">
      <h2>Панель управления</h2>
      <p>Компактная версия Mini App. Без липкой нижней панели, чтобы нормально листалось в Telegram.</p>
    </section>

    <nav class="tabs">
      <button class="tab active" onclick="openPage('home', this)">Главная</button>
      <button class="tab" onclick="openPage('groups', this)">Группы</button>
      <button class="tab" onclick="openPage('ai', this)">AI</button>
      <button class="tab" onclick="openPage('content', this)">Контент</button>
      <button class="tab" onclick="openPage('images', this)">Картинки</button>
      <button class="tab" onclick="openPage('memory', this)">Память</button>
      <button class="tab" onclick="openPage('schedule', this)">План</button>
      <button class="tab" onclick="openPage('admin', this)">Admin</button>
    </nav>

    <main>
      <section id="home" class="page active">
        <div class="section">
          <div class="section-head"><h3>Быстрый старт</h3><small>основное</small></div>
          <div class="grid two">
            <button class="btn primary" onclick="sendAction('status')"><span>📊 Статус<small>Проверить бота</small></span><b>›</b></button>
            <button class="btn" onclick="sendAction('group_debug')"><span>🛠 Group Debug<small>Почему отвечает/молчит</small></span><b>›</b></button>
            <button class="btn" onclick="sendAction('ai_model_test')"><span>🧪 AI Test<small>Проверить модель</small></span><b>›</b></button>
            <button class="btn" onclick="sendAction('content_help')"><span>📝 Контент<small>Посты и планы</small></span><b>›</b></button>
          </div>
        </div>

        <details open>
          <summary>Полезные команды</summary>
          <div class="details-body">
            <div class="cmd">/ai что мы тут обсуждали?</div>
            <div class="cmd">/image аватарка Balern AI, dark tech style</div>
            <div class="cmd">/post_ideas spbRac1ng</div>
            <div class="cmd">/remind_in 30m проверить пост</div>
          </div>
        </details>
      </section>

      <section id="groups" class="page">
        <div class="section">
          <div class="section-head"><h3>Группы</h3><small>режимы и участники</small></div>
          <div class="grid two">
            <button class="btn primary" onclick="openExternal('https://t.me/balernai_bot?startgroup=true')"><span>➕ Добавить в чат<small>Откроется Telegram</small></span><b>›</b></button>
            <button class="btn" onclick="sendAction('group_help')"><span>📘 Помощь<small>Как пользоваться</small></span><b>›</b></button>
          </div>
        </div>

        <details open>
          <summary>Режим группы</summary>
          <div class="details-body grid two">
            <button class="btn primary" onclick="sendAction('group_mode_status')"><span>⚙️ Текущий режим<small>Статус</small></span><b>›</b></button>
            <button class="btn" onclick="sendAction('group_mode_quiet')"><span>🤫 Quiet<small>Слушает</small></span><b>›</b></button>
            <button class="btn" onclick="sendAction('group_mode_balanced')"><span>⚖️ Balanced<small>Когда зовут</small></span><b>›</b></button>
            <button class="btn" onclick="sendAction('group_mode_active')"><span>🔥 Active<small>Иногда сам</small></span><b>›</b></button>
            <button class="btn danger" onclick="sendAction('group_mode_chaos')"><span>🧨 Chaos<small>Тест</small></span><b>›</b></button>
            <button class="btn" onclick="sendAction('group_modes_help')"><span>📋 О режимах<small>Описание</small></span><b>›</b></button>
          </div>
        </details>

        <details>
          <summary>Стиль группы</summary>
          <div class="details-body grid two">
            <button class="btn primary" onclick="sendAction('group_personality_status')"><span>🎭 Текущий стиль<small>Показать</small></span><b>›</b></button>
            <button class="btn" onclick="sendAction('group_personality_bro')"><span>😎 Bro<small>Братан</small></span><b>›</b></button>
            <button class="btn" onclick="sendAction('group_personality_serious')"><span>🧊 Serious<small>Строго</small></span><b>›</b></button>
            <button class="btn" onclick="sendAction('group_personality_memes')"><span>💀 Memes<small>Вайб</small></span><b>›</b></button>
            <button class="btn" onclick="sendAction('group_personality_helper')"><span>🛠 Helper<small>Польза</small></span><b>›</b></button>
            <button class="btn" onclick="sendAction('group_personality_help')"><span>📋 О стилях<small>Помощь</small></span><b>›</b></button>
          </div>
        </details>

        <details>
          <summary>Участники</summary>
          <div class="details-body grid two">
            <button class="btn" onclick="sendAction('group_users')"><span>👥 Участники<small>Список</small></span><b>›</b></button>
            <button class="btn" onclick="sendAction('profile_me')"><span>🙋 Мой профиль<small>Что знает бот</small></span><b>›</b></button>
          </div>
        </details>
      </section>

      <section id="ai" class="page">
        <div class="section">
          <div class="section-head"><h3>AI</h3><small>модели и контекст</small></div>
          <div class="grid two">
            <button class="btn primary" onclick="sendAction('ai_router_status')"><span>🧭 AI Router<small>Fallback и ошибки</small></span><b>›</b></button>
            <button class="btn" onclick="sendAction('ai_model_test')"><span>🧪 AI Test<small>Проверить модель</small></span><b>›</b></button>
            <button class="btn" onclick="sendAction('group_ai_command_help')"><span>💬 /ai help<small>Как спрашивать</small></span><b>›</b></button>
            <button class="btn" onclick="sendAction('group_context')"><span>🧾 Контекст<small>Последние сообщения</small></span><b>›</b></button>
          </div>
        </div>
        <div class="cmd">/ai что ты помнишь по этой группе?</div>
        <div class="cmd">/ai_models</div>
      </section>

      <section id="content" class="page">
        <div class="section">
          <div class="section-head"><h3>Контент</h3><small>посты и идеи</small></div>
          <div class="grid two">
            <button class="btn primary" onclick="sendAction('content_help')"><span>📝 Content Help<small>Все команды</small></span><b>›</b></button>
            <button class="btn" onclick="sendAction('post_ideas_help')"><span>💡 Идеи<small>/post_ideas</small></span><b>›</b></button>
            <button class="btn" onclick="sendAction('make_post_help')"><span>✍️ Пост<small>/make_post</small></span><b>›</b></button>
            <button class="btn" onclick="sendAction('content_plan_help')"><span>📅 План<small>/content_plan</small></span><b>›</b></button>
            <button class="btn" onclick="sendAction('channel_style')"><span>🎛 Стиль<small>Канал/проект</small></span><b>›</b></button>
          </div>
        </div>
        <div class="cmd">/post_ideas street racing для Telegram</div>
        <div class="cmd">/make_post пост для КУЛЬТА про запись</div>
        <div class="cmd">/content_plan spbRac1ng на неделю</div>
      </section>

      <section id="images" class="page">
        <div class="section">
          <div class="section-head"><h3>Картинки</h3><small>image workflow</small></div>
          <div class="grid two">
            <button class="btn primary" onclick="sendAction('image_workflow_help')"><span>🧩 Workflow<small>Промпты</small></span><b>›</b></button>
            <button class="btn" onclick="sendAction('image_help')"><span>🎨 Генерация<small>/image</small></span><b>›</b></button>
            <button class="btn" onclick="sendAction('image_prompt_help')"><span>✨ Улучшить<small>/image_prompt</small></span><b>›</b></button>
            <button class="btn" onclick="sendAction('image_variants_help')"><span>🧬 Варианты<small>4 промпта</small></span><b>›</b></button>
            <button class="btn" onclick="sendAction('image_history')"><span>🕘 История<small>Промпты</small></span><b>›</b></button>
            <button class="btn" onclick="sendAction('image_favorites')"><span>⭐ Избранное<small>Любимые</small></span><b>›</b></button>
          </div>
        </div>
        <div class="cmd">/image аватарка Balern AI, dark tech style</div>
        <div class="cmd">/image_prompt постер spbRac1ng, ночной BMW</div>
      </section>

      <section id="memory" class="page">
        <details open>
          <summary>Память группы</summary>
          <div class="details-body grid two">
            <button class="btn primary" onclick="sendAction('group_status')"><span>📊 Статус<small>Память</small></span><b>›</b></button>
            <button class="btn" onclick="sendAction('group_listen_on')"><span>▶️ Включить<small>Слушание</small></span><b>›</b></button>
            <button class="btn" onclick="sendAction('group_listen_off')"><span>⏸ Выключить<small>Слушание</small></span><b>›</b></button>
            <button class="btn" onclick="sendAction('group_memory')"><span>🧠 История<small>Последние</small></span><b>›</b></button>
            <button class="btn danger" onclick="sendAction('group_forget')"><span>🗑 Очистить<small>Raw memory</small></span><b>›</b></button>
          </div>
        </details>

        <details>
          <summary>Summary</summary>
          <div class="details-body grid two">
            <button class="btn primary" onclick="sendAction('group_summary')"><span>🧠 Summary<small>Сводка</small></span><b>›</b></button>
            <button class="btn" onclick="sendAction('group_topics')"><span>🏷 Темы<small>Topics</small></span><b>›</b></button>
            <button class="btn" onclick="sendAction('group_autosummary_status')"><span>🔄 Auto Summary<small>Статус</small></span><b>›</b></button>
            <button class="btn" onclick="sendAction('group_autosummary_on')"><span>▶️ Auto ON<small>Включить</small></span><b>›</b></button>
            <button class="btn" onclick="sendAction('group_autosummary_off')"><span>⏸ Auto OFF<small>Выключить</small></span><b>›</b></button>
            <button class="btn danger" onclick="sendAction('group_summary_forget')"><span>🗑 Очистить<small>Summary</small></span><b>›</b></button>
          </div>
        </details>
      </section>

      <section id="schedule" class="page">
        <div class="section">
          <div class="section-head"><h3>План</h3><small>напоминания</small></div>
          <div class="grid two">
            <button class="btn primary" onclick="sendAction('scheduler_help')"><span>⏰ Help<small>Команды</small></span><b>›</b></button>
            <button class="btn" onclick="sendAction('scheduled')"><span>📋 Список<small>Активные</small></span><b>›</b></button>
            <button class="btn" onclick="sendAction('remind_help')"><span>➕ Создать<small>Примеры</small></span><b>›</b></button>
          </div>
        </div>
        <div class="cmd">/remind_in 10m проверить пост</div>
        <div class="cmd">/remind_tomorrow 12:00 идеи для канала</div>
      </section>

      <section id="admin" class="page">
        <div class="section">
          <div class="section-head"><h3>Admin</h3><small>статистика</small></div>
          <div class="grid two">
            <button class="btn primary" onclick="sendAction('admin_stats')"><span>📊 Admin Stats<small>Глобально</small></span><b>›</b></button>
            <button class="btn" onclick="sendAction('stats')"><span>📈 Chat Stats<small>Этот чат</small></span><b>›</b></button>
            <button class="btn" onclick="sendAction('analytics_top')"><span>🏆 Top<small>Команды</small></span><b>›</b></button>
            <button class="btn danger" onclick="sendAction('analytics_errors')"><span>🧯 Errors<small>Ошибки</small></span><b>›</b></button>
            <button class="btn" onclick="sendAction('analytics_help')"><span>📘 Help<small>Analytics</small></span><b>›</b></button>
            <button class="btn" onclick="sendAction('group_debug')"><span>🛠 Debug<small>Группа</small></span><b>›</b></button>
          </div>
        </div>
      </section>
    </main>

    <div class="footer">@balernai_bot</div>
  </div>

  <div class="toast" id="toast">Отправлено</div>

  <script>
    const tg = window.Telegram && window.Telegram.WebApp ? window.Telegram.WebApp : null;

    function initTelegram(){
      if(!tg) return;
      try{
        tg.ready();
        tg.expand();
        tg.setHeaderColor('#071018');
        tg.setBackgroundColor('#071018');
        if(tg.disableVerticalSwipes) tg.disableVerticalSwipes();
      }catch(e){}
    }

    function toast(text){
      const el = document.getElementById('toast');
      el.textContent = text || 'Отправлено';
      el.classList.add('show');
      clearTimeout(window.__toastTimer);
      window.__toastTimer = setTimeout(()=>el.classList.remove('show'), 1350);
    }

    function payload(action){
      return JSON.stringify({ action: action, source: 'mini_app_3_4b_compact', ts: Date.now() });
    }

    function sendAction(action){
      try{
        if(tg && tg.sendData){
          tg.sendData(payload(action));
          toast('Отправлено: ' + action);
        }else{
          console.log('Action:', action);
          toast('Открой через Telegram');
        }
      }catch(e){
        console.error(e);
        toast('Ошибка отправки');
      }
    }

    function openPage(id, btn){
      document.querySelectorAll('.page').forEach(p => p.classList.remove('active'));
      const page = document.getElementById(id);
      if(page) page.classList.add('active');

      document.querySelectorAll('.tab').forEach(t => t.classList.remove('active'));
      if(btn) btn.classList.add('active');

      setTimeout(() => window.scrollTo({ top: 0, behavior: 'smooth' }), 20);

      try{
        if(tg && tg.HapticFeedback) tg.HapticFeedback.selectionChanged();
      }catch(e){}
    }

    function openExternal(url){
      try{
        if(tg && tg.openTelegramLink && url.includes('t.me/')){
          tg.openTelegramLink(url);
          return;
        }
        if(tg && tg.openLink){
          tg.openLink(url);
          return;
        }
      }catch(e){}
      window.open(url, '_blank');
    }

    function closeApp(){
      try{
        if(tg){ tg.close(); return; }
      }catch(e){}
      toast('Можно закрыть окно');
    }

    initTelegram();
  </script>
</body>
</html>
