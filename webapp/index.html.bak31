<!doctype html>
<html lang="ru">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1,viewport-fit=cover" />
  <title>Balern AI</title>
  <script src="https://telegram.org/js/telegram-web-app.js"></script>
  <style>
    :root{
      --bg0:#05070d;
      --bg1:#07111d;
      --card:rgba(255,255,255,.075);
      --card2:rgba(255,255,255,.105);
      --stroke:rgba(255,255,255,.14);
      --stroke2:rgba(125,255,210,.30);
      --text:#f4f7fb;
      --muted:rgba(244,247,251,.67);
      --muted2:rgba(244,247,251,.45);
      --accent:#72ffd6;
      --accent2:#78a7ff;
      --danger:#ff6b8b;
      --warning:#ffd36e;
      --shadow:0 24px 80px rgba(0,0,0,.45);
      --radius:26px;
      --radius2:18px;
      --bar:rgba(5,7,13,.72);
      --blur:blur(22px);
      font-synthesis-weight:none;
    }

    *{box-sizing:border-box}
    html,body{margin:0;min-height:100%;background:var(--bg0);color:var(--text);font-family:Inter,system-ui,-apple-system,BlinkMacSystemFont,"Segoe UI",Roboto,Arial,sans-serif}
    body{
      overflow-x:hidden;
      background:
        radial-gradient(circle at 15% 2%, rgba(114,255,214,.20), transparent 38%),
        radial-gradient(circle at 95% 10%, rgba(120,167,255,.24), transparent 34%),
        radial-gradient(circle at 50% 105%, rgba(255,107,139,.14), transparent 35%),
        linear-gradient(160deg,var(--bg0),var(--bg1) 58%,#05070d);
    }

    .noise{
      pointer-events:none;
      position:fixed;inset:0;z-index:0;
      opacity:.12;
      background-image:
        linear-gradient(rgba(255,255,255,.035) 1px, transparent 1px),
        linear-gradient(90deg, rgba(255,255,255,.035) 1px, transparent 1px);
      background-size:42px 42px;
      mask-image:linear-gradient(to bottom, black, transparent 80%);
    }

    .app{position:relative;z-index:1;min-height:100vh;padding:18px 14px 98px;max-width:740px;margin:0 auto}
    .top{
      position:sticky;top:0;z-index:50;margin:-18px -14px 14px;padding:calc(14px + env(safe-area-inset-top)) 14px 12px;
      background:linear-gradient(to bottom,rgba(5,7,13,.90),rgba(5,7,13,.52),transparent);
      backdrop-filter:var(--blur);
    }
    .top-inner{display:flex;align-items:center;gap:12px}
    .logo{
      width:44px;height:44px;border-radius:16px;display:grid;place-items:center;
      background:linear-gradient(135deg,rgba(114,255,214,.92),rgba(120,167,255,.74));
      color:#061016;font-weight:950;letter-spacing:-.05em;box-shadow:0 0 34px rgba(114,255,214,.22)
    }
    .title{min-width:0;flex:1}
    .title h1{margin:0;font-size:22px;line-height:1.02;letter-spacing:-.04em}
    .title p{margin:3px 0 0;color:var(--muted);font-size:12.5px}
    .pill{
      border:1px solid var(--stroke);border-radius:999px;padding:8px 10px;color:var(--muted);
      background:rgba(255,255,255,.055);font-size:12px;white-space:nowrap
    }

    .hero{
      position:relative;overflow:hidden;border:1px solid var(--stroke);border-radius:32px;padding:20px;
      background:linear-gradient(135deg,rgba(255,255,255,.11),rgba(255,255,255,.045));
      box-shadow:var(--shadow);
    }
    .hero:before{
      content:"";position:absolute;inset:-1px;z-index:-1;
      background:
        radial-gradient(circle at 18% 10%,rgba(114,255,214,.25),transparent 32%),
        radial-gradient(circle at 90% 20%,rgba(120,167,255,.22),transparent 28%);
    }
    .hero h2{margin:0;font-size:28px;line-height:1.02;letter-spacing:-.055em}
    .hero p{margin:10px 0 0;color:var(--muted);font-size:14.5px;line-height:1.45}
    .hero-actions{display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-top:16px}
    .hero-actions .btn{margin:0}

    .stats{display:grid;grid-template-columns:repeat(3,1fr);gap:10px;margin:14px 0}
    .stat{
      border:1px solid var(--stroke);border-radius:20px;padding:13px 12px;background:rgba(255,255,255,.06);
      min-height:78px
    }
    .stat b{display:block;font-size:18px;letter-spacing:-.04em}
    .stat span{display:block;color:var(--muted);font-size:11.5px;margin-top:4px;line-height:1.25}

    .tabs-wrap{
      position:sticky;top:72px;z-index:45;margin:14px -14px 14px;padding:9px 14px;
      background:linear-gradient(to bottom,rgba(5,7,13,.72),rgba(5,7,13,.48));
      backdrop-filter:var(--blur);
      border-top:1px solid rgba(255,255,255,.04);
      border-bottom:1px solid rgba(255,255,255,.04);
    }
    .tabs{display:flex;gap:8px;overflow:auto;scrollbar-width:none}
    .tabs::-webkit-scrollbar{display:none}
    .tab{
      appearance:none;border:1px solid var(--stroke);background:rgba(255,255,255,.055);color:var(--muted);
      padding:10px 13px;border-radius:999px;font-size:13px;font-weight:800;white-space:nowrap
    }
    .tab.active{color:#04110e;background:linear-gradient(135deg,var(--accent),#9fffe6);border-color:rgba(114,255,214,.55);box-shadow:0 0 28px rgba(114,255,214,.16)}

    .page{display:none;animation:fade .18s ease-out}
    .page.active{display:block}
    @keyframes fade{from{opacity:.0;transform:translateY(4px)}to{opacity:1;transform:translateY(0)}}

    .section{margin:14px 0}
    .section-head{display:flex;align-items:end;justify-content:space-between;gap:12px;margin:0 2px 9px}
    .section h3{margin:0;font-size:18px;letter-spacing:-.04em}
    .section small{color:var(--muted2);font-size:12px;line-height:1.25}

    .grid{display:grid;grid-template-columns:1fr;gap:10px}
    .grid.two{grid-template-columns:1fr 1fr}
    @media (min-width:560px){.grid.auto{grid-template-columns:1fr 1fr}}

    .card{
      border:1px solid var(--stroke);border-radius:var(--radius);background:rgba(255,255,255,.065);
      box-shadow:0 18px 60px rgba(0,0,0,.24);
      padding:14px;
    }

    .btn{
      width:100%;appearance:none;border:1px solid var(--stroke);border-radius:22px;
      background:linear-gradient(135deg,rgba(255,255,255,.10),rgba(255,255,255,.052));
      color:var(--text);display:flex;align-items:center;justify-content:space-between;gap:12px;
      padding:14px 14px;text-align:left;font-weight:900;font-size:14.5px;letter-spacing:-.02em;
      box-shadow:0 12px 32px rgba(0,0,0,.18);
      cursor:pointer;
      -webkit-tap-highlight-color:transparent;
    }
    .btn:active{transform:scale(.99)}
    .btn.primary{background:linear-gradient(135deg,var(--accent),#8de6ff);color:#03110e;border-color:rgba(114,255,214,.64)}
    .btn.blue{background:linear-gradient(135deg,rgba(120,167,255,.92),rgba(162,205,255,.88));color:#06101f;border-color:rgba(120,167,255,.54)}
    .btn.danger{background:linear-gradient(135deg,rgba(255,107,139,.23),rgba(255,255,255,.06));border-color:rgba(255,107,139,.36)}
    .btn.warning{background:linear-gradient(135deg,rgba(255,211,110,.20),rgba(255,255,255,.06));border-color:rgba(255,211,110,.34)}
    .btn span{display:block;min-width:0}
    .btn small{display:block;margin-top:3px;color:inherit;opacity:.64;font-weight:700;font-size:11.5px;line-height:1.25}
    .btn b{font-size:22px;line-height:1;opacity:.58}

    .cmd{
      display:block;border:1px solid rgba(255,255,255,.11);background:rgba(0,0,0,.22);
      border-radius:16px;padding:10px 12px;color:var(--muted);font-family:ui-monospace,SFMono-Regular,Menlo,Consolas,monospace;
      font-size:12px;overflow:auto;white-space:nowrap
    }
    .hint{color:var(--muted);font-size:12.5px;line-height:1.4;margin:8px 2px 0}
    .sep{height:1px;background:rgba(255,255,255,.09);margin:14px 0}

    .bottom{
      position:fixed;z-index:100;left:0;right:0;bottom:0;padding:10px 14px calc(10px + env(safe-area-inset-bottom));
      background:rgba(5,7,13,.78);backdrop-filter:var(--blur);border-top:1px solid rgba(255,255,255,.10)
    }
    .bottom-inner{max-width:740px;margin:0 auto;display:grid;grid-template-columns:1fr auto;gap:10px}
    .toast{
      position:fixed;left:50%;bottom:90px;z-index:200;transform:translateX(-50%) translateY(12px);
      background:rgba(8,13,20,.94);border:1px solid var(--stroke);border-radius:999px;padding:10px 14px;
      color:var(--text);font-size:13px;opacity:0;pointer-events:none;transition:.2s;box-shadow:var(--shadow);
      max-width:calc(100vw - 28px);white-space:nowrap;overflow:hidden;text-overflow:ellipsis
    }
    .toast.show{opacity:1;transform:translateX(-50%) translateY(0)}
    .close-btn{width:auto;padding:14px 18px;justify-content:center}
  </style>
</head>

<body>
  <div class="noise"></div>
  <div class="app">
    <header class="top">
      <div class="top-inner">
        <div class="logo">BA</div>
        <div class="title">
          <h1>Balern AI</h1>
          <p>Mini App Control Center</p>
        </div>
        <div class="pill" id="tgStatus">Telegram</div>
      </div>
    </header>

    <section class="hero">
      <h2>Панель управления ботом</h2>
      <p>Группы, память, AI Router, картинки, режимы и диагностика — в одном месте. Открывай через кнопку бота, чтобы действия доходили до Telegram.</p>
      <div class="hero-actions">
        <button class="btn primary" onclick="sendAction('status')"><span>📊 Статус<small>Проверить бота</small></span><b>›</b></button>
        <button class="btn blue" onclick="sendAction('ai_model_test')"><span>🧪 AI Test<small>Проверить модель</small></span><b>›</b></button>
      </div>
    </section>

    <section class="stats">
      <div class="stat"><b>2.9</b><span>AI Router + fallback</span></div>
      <div class="stat"><b>Group</b><span>memory, summary, profiles</span></div>
      <div class="stat"><b>UX</b><span>new Mini App shell</span></div>
    </section>

    <div class="tabs-wrap">
      <nav class="tabs" id="tabs">
        <button class="tab active" onclick="openPage('home', this)">Главная</button>
        <button class="tab" onclick="openPage('groups', this)">Группы</button>
        <button class="tab" onclick="openPage('ai', this)">AI</button>
        <button class="tab" onclick="openPage('images', this)">Картинки</button>
        <button class="tab" onclick="openPage('memory', this)">Память</button>
        <button class="tab" onclick="openPage('debug', this)">Debug</button>
      </nav>
    </div>

    <main>
      <section id="home" class="page active">
        <div class="section">
          <div class="section-head">
            <h3>Быстрый старт</h3>
            <small>самые частые действия</small>
          </div>
          <div class="grid auto">
            <button class="btn primary" onclick="sendAction('group_mode_status')"><span>⚙️ Режим группы<small>quiet / balanced / active / chaos</small></span><b>›</b></button>
            <button class="btn" onclick="sendAction('group_debug')"><span>🛠 Group Debug<small>Почему бот отвечает / не отвечает</small></span><b>›</b></button>
            <button class="btn" onclick="sendAction('group_summary')"><span>🧠 Сводка группы<small>Долгая память группы</small></span><b>›</b></button>
            <button class="btn" onclick="sendAction('ai_router_status')"><span>🧭 AI Router<small>Fallback-модели и ошибки</small></span><b>›</b></button>
          </div>
        </div>

        <div class="section card">
          <div class="section-head">
            <h3>Команды, которые стоит помнить</h3>
          </div>
          <div class="cmd">/ai что мы тут обсуждали?</div>
          <div class="cmd" style="margin-top:8px">/group_mode active</div>
          <div class="cmd" style="margin-top:8px">/group_summarize</div>
          <div class="cmd" style="margin-top:8px">/ai_model_test</div>
          <p class="hint">В группе /ai использует память, summary, стиль группы и профили участников.</p>
        </div>
      </section>

      <section id="groups" class="page">
        <div class="section">
          <div class="section-head">
            <h3>Подключение</h3>
            <small>добавление и помощь</small>
          </div>
          <div class="grid">
            <button class="btn primary" onclick="openExternal('https://t.me/balernai_bot?startgroup=true')"><span>➕ Добавить бота в чат<small>Откроется Telegram</small></span><b>›</b></button>
            <button class="btn" onclick="sendAction('group_help')"><span>📘 Как пользоваться в группе<small>/ai, /image, /app, privacy mode</small></span><b>›</b></button>
          </div>
        </div>

        <div class="section">
          <div class="section-head"><h3>Режим группы</h3><small>всё одной кнопкой</small></div>
          <div class="grid auto">
            <button class="btn primary" onclick="sendAction('group_mode_status')"><span>⚙️ Текущий режим<small>Показать настройки</small></span><b>›</b></button>
            <button class="btn" onclick="sendAction('group_mode_quiet')"><span>🤫 Quiet<small>Слушает, но молчит</small></span><b>›</b></button>
            <button class="btn" onclick="sendAction('group_mode_balanced')"><span>⚖️ Balanced<small>Отвечает, когда зовут</small></span><b>›</b></button>
            <button class="btn" onclick="sendAction('group_mode_active')"><span>🔥 Active<small>Иногда включается сам</small></span><b>›</b></button>
            <button class="btn danger" onclick="sendAction('group_mode_chaos')"><span>🧨 Chaos<small>Тестовый режим</small></span><b>›</b></button>
            <button class="btn" onclick="sendAction('group_modes_help')"><span>📋 О режимах<small>Описание режимов</small></span><b>›</b></button>
          </div>
        </div>

        <div class="section">
          <div class="section-head"><h3>Стиль группы</h3><small>personality</small></div>
          <div class="grid auto">
            <button class="btn primary" onclick="sendAction('group_personality_status')"><span>🎭 Текущий стиль<small>Показать характер</small></span><b>›</b></button>
            <button class="btn" onclick="sendAction('group_personality_bro')"><span>😎 Bro<small>Умный братан</small></span><b>›</b></button>
            <button class="btn" onclick="sendAction('group_personality_serious')"><span>🧊 Serious<small>Строго по делу</small></span><b>›</b></button>
            <button class="btn" onclick="sendAction('group_personality_memes')"><span>💀 Memes<small>Вайб и приколы</small></span><b>›</b></button>
            <button class="btn" onclick="sendAction('group_personality_helper')"><span>🛠 Helper<small>Максимум пользы</small></span><b>›</b></button>
            <button class="btn" onclick="sendAction('group_personality_help')"><span>📋 О стилях<small>Все варианты</small></span><b>›</b></button>
          </div>
        </div>

        <div class="section">
          <div class="section-head"><h3>Участники</h3><small>profiles</small></div>
          <div class="grid auto">
            <button class="btn" onclick="sendAction('group_users')"><span>👥 Участники группы<small>Кто известен боту</small></span><b>›</b></button>
            <button class="btn" onclick="sendAction('profile_me')"><span>🙋 Мой профиль<small>Что бот знает обо мне</small></span><b>›</b></button>
          </div>
        </div>
      </section>

      <section id="ai" class="page">
        <div class="section">
          <div class="section-head"><h3>AI Router</h3><small>fallback и диагностика</small></div>
          <div class="grid">
            <button class="btn primary" onclick="sendAction('ai_router_status')"><span>🧭 AI Router Status<small>Модели, ошибки, успешные ответы</small></span><b>›</b></button>
            <button class="btn blue" onclick="sendAction('ai_model_test')"><span>🧪 AI Model Test<small>Проверить доступность модели</small></span><b>›</b></button>
          </div>
        </div>

        <div class="section">
          <div class="section-head"><h3>Group-aware AI</h3><small>/ai + память группы</small></div>
          <div class="grid">
            <button class="btn" onclick="sendAction('group_ai_command_help')"><span>💬 Как пользоваться /ai<small>/ai помнит историю группы</small></span><b>›</b></button>
            <button class="btn" onclick="sendAction('group_context')"><span>🧾 Текущий контекст<small>Последние сообщения группы</small></span><b>›</b></button>
            <button class="btn" onclick="sendAction('group_ai_help')"><span>🤖 Инструкция /gai<small>Старый group-aware режим</small></span><b>›</b></button>
          </div>
        </div>

        <div class="section card">
          <h3 style="margin:0 0 10px">Проверочные команды</h3>
          <div class="cmd">/ai_models</div>
          <div class="cmd" style="margin-top:8px">/ai_model_test</div>
          <div class="cmd" style="margin-top:8px">/ai что ты помнишь по этой группе?</div>
        </div>
      </section>

      <section id="images" class="page">
        <div class="section">
          <div class="section-head"><h3>Картинки</h3><small>генерация и стили</small></div>
          <div class="grid">
            <button class="btn primary" onclick="sendAction('image_help')"><span>🎨 Как генерировать<small>Команды и примеры</small></span><b>›</b></button>
            <button class="btn" onclick="sendAction('image_styles')"><span>🎭 Стили генерации<small>Пресеты и подсказки</small></span><b>›</b></button>
            <button class="btn" onclick="sendAction('image_edit_help')"><span>🖼 Редактирование фото<small>Как отправлять фото + запрос</small></span><b>›</b></button>
          </div>
        </div>

        <div class="section card">
          <h3 style="margin:0 0 10px">Примеры</h3>
          <div class="cmd">/image аватарка Balern AI, тёмный tech style</div>
          <div class="cmd" style="margin-top:8px">/image постер для Telegram-канала</div>
          <p class="hint">Если какая-то кнопка не отвечает — значит backend-action ещё не добавлен, команда в чате всё равно работает.</p>
        </div>
      </section>

      <section id="memory" class="page">
        <div class="section">
          <div class="section-head"><h3>Память группы</h3><small>raw memory</small></div>
          <div class="grid auto">
            <button class="btn primary" onclick="sendAction('group_status')"><span>📊 Статус памяти<small>Слушает или нет</small></span><b>›</b></button>
            <button class="btn" onclick="sendAction('group_listen_on')"><span>▶️ Включить слушание<small>Сохранять сообщения</small></span><b>›</b></button>
            <button class="btn" onclick="sendAction('group_listen_off')"><span>⏸ Выключить слушание<small>Не сохранять новые</small></span><b>›</b></button>
            <button class="btn" onclick="sendAction('group_memory')"><span>🧠 Память группы<small>Показать последние сообщения</small></span><b>›</b></button>
            <button class="btn danger" onclick="sendAction('group_forget')"><span>🗑 Очистить память<small>Удалить raw history</small></span><b>›</b></button>
          </div>
        </div>

        <div class="section">
          <div class="section-head"><h3>Summary Memory</h3><small>долгая суть</small></div>
          <div class="grid auto">
            <button class="btn primary" onclick="sendAction('group_summary')"><span>🧠 Сводка группы<small>Показать summary</small></span><b>›</b></button>
            <button class="btn" onclick="sendAction('group_topics')"><span>🏷 Темы группы<small>Основные темы</small></span><b>›</b></button>
            <button class="btn" onclick="sendAction('group_autosummary_status')"><span>🔄 Auto Summary<small>Статус автосводки</small></span><b>›</b></button>
            <button class="btn" onclick="sendAction('group_autosummary_on')"><span>▶️ Включить Auto Summary<small>Обновлять summary автоматически</small></span><b>›</b></button>
            <button class="btn" onclick="sendAction('group_autosummary_off')"><span>⏸ Выключить Auto Summary<small>Только вручную</small></span><b>›</b></button>
            <button class="btn danger" onclick="sendAction('group_summary_forget')"><span>🗑 Очистить summary<small>Удалить сводку</small></span><b>›</b></button>
          </div>
        </div>
      </section>

      <section id="debug" class="page">
        <div class="section">
          <div class="section-head"><h3>Диагностика</h3><small>когда что-то тупит</small></div>
          <div class="grid">
            <button class="btn primary" onclick="sendAction('group_debug')"><span>🛠 Group Debug<small>Память, режимы, cooldown, ошибки</small></span><b>›</b></button>
            <button class="btn" onclick="sendAction('ai_router_status')"><span>🧭 AI Router Debug<small>Модели и ошибки нейросети</small></span><b>›</b></button>
            <button class="btn" onclick="sendAction('group_auto_status')"><span>🤖 Auto Reply Status<small>Автоответы, cooldown</small></span><b>›</b></button>
            <button class="btn" onclick="sendAction('group_proactive_status')"><span>🌱 Proactive Status<small>Шанс, cooldown, состояние</small></span><b>›</b></button>
          </div>
        </div>

        <div class="section card">
          <h3 style="margin:0 0 10px">Что проверять первым</h3>
          <div class="cmd">/group_debug</div>
          <div class="cmd" style="margin-top:8px">/ai_router_status</div>
          <div class="cmd" style="margin-top:8px">/group_mode</div>
          <p class="hint">Если в консоли Status: 200, но в чат не пришло — это чаще всего Telegram API / сеть, а не модель.</p>
        </div>
      </section>
    </main>
  </div>

  <div class="toast" id="toast">Отправлено</div>

  <div class="bottom">
    <div class="bottom-inner">
      <button class="btn primary" onclick="sendAction('status')"><span>📊 Проверить статус<small>Бот ответит в чат</small></span><b>›</b></button>
      <button class="btn close-btn" onclick="closeApp()">✕</button>
    </div>
  </div>

  <script>
    const tg = window.Telegram && window.Telegram.WebApp ? window.Telegram.WebApp : null;

    function initTelegram(){
      if(!tg){
        document.getElementById('tgStatus').textContent = 'Browser';
        return;
      }
      try{
        tg.ready();
        tg.expand();
        tg.setHeaderColor('#05070d');
        tg.setBackgroundColor('#05070d');
        document.getElementById('tgStatus').textContent = 'Mini App';
      }catch(e){
        document.getElementById('tgStatus').textContent = 'Telegram';
      }
    }

    function toast(text){
      const el = document.getElementById('toast');
      el.textContent = text || 'Отправлено';
      el.classList.add('show');
      setTimeout(()=>el.classList.remove('show'), 1600);
    }

    function payload(action){
      return JSON.stringify({ action: action, source: 'mini_app_v3_0', ts: Date.now() });
    }

    function sendAction(action){
      if(!action) return;
      try{
        if(tg && tg.sendData){
          tg.sendData(payload(action));
          toast('Отправлено: ' + action);
        }else{
          console.log('Mini App action:', action);
          toast('Открой через Telegram: ' + action);
        }
      }catch(e){
        console.error(e);
        toast('Ошибка отправки');
      }
    }

    function openExternal(url){
      try{
        if(tg && tg.openTelegramLink && url.includes('t.me/')){
          tg.openTelegramLink(url);
          return;
        }
        if(tg && tg.openLink){
          tg.openLink(url);
          return;
        }
      }catch(e){}
      window.open(url, '_blank');
    }

    function closeApp(){
      try{
        if(tg){ tg.close(); return; }
      }catch(e){}
      toast('Можно закрыть окно');
    }

    function openPage(id, btn){
      document.querySelectorAll('.page').forEach(p=>p.classList.remove('active'));
      const page = document.getElementById(id);
      if(page) page.classList.add('active');

      document.querySelectorAll('.tab').forEach(t=>t.classList.remove('active'));
      if(btn) btn.classList.add('active');

      window.scrollTo({top:0, behavior:'smooth'});
      try{ if(tg && tg.HapticFeedback) tg.HapticFeedback.selectionChanged(); }catch(e){}
    }

    initTelegram();
  </script>
</body>
</html>
